# Suiki — Environment Variables
# Copy this to .env.local and fill in your values

# SUI Network
NEXT_PUBLIC_SUI_NETWORK=devnet

# Deployed contract package ID (devnet)
NEXT_PUBLIC_PACKAGE_ID=0x8cedc23e4534dfc7e4a0ae7254d6c44dd45f760ee125a5387727bc5b884a3496

# Gas sponsor private key (base64-encoded ed25519 key)
# Generate: sui keytool generate ed25519
# NEVER commit real keys — this is the deployer key for devnet testing only
SPONSOR_PRIVATE_KEY=_BASE64_ENCODED_ED25519_KEY
