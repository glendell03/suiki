# =============================================================================
# Suiki — Environment Variable Reference
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is listed in .gitignore.
# =============================================================================

# SUI Network: testnet | mainnet | devnet
NEXT_PUBLIC_SUI_NETWORK=testnet

# Feature flag: set to "true" to enable gas sponsorship via /api/sponsor.
# Keep "false" during development — users pay their own gas.
NEXT_PUBLIC_ENABLE_SPONSOR_GAS=false

# Deployed Move package ID (fill after Task 4: Deploy)
NEXT_PUBLIC_PACKAGE_ID=0x_PLACEHOLDER_AFTER_DEPLOY

# =============================================================================
# SECURITY WARNING — SPONSOR_PRIVATE_KEY
# This is the Ed25519 private key used to sponsor (pay gas for) blockchain
# transactions on behalf of users. Anyone who obtains this value can drain
# the sponsor wallet.
#
# Rules:
#   1. NEVER commit this value to source control.
#   2. NEVER expose this variable with the NEXT_PUBLIC_ prefix.
#   3. In production, inject via your hosting platform's secrets manager
#      (e.g. Vercel Environment Variables, AWS Secrets Manager).
#   4. Rotate immediately if you suspect exposure.
# =============================================================================
# Format: bech32-encoded Ed25519 private key (@mysten/sui v2+ format)
# Generate with: node -e "import('@mysten/sui/keypairs/ed25519').then(m=>console.log(new m.Ed25519Keypair().getSecretKey()))"
# Starts with "suiprivkey1..."
SPONSOR_PRIVATE_KEY=suiprivkey1...
